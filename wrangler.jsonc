// Cloudflare Workers deploy config (static assets only, no server code).
// The Cloudflare git integration runs `npm run build` then `npx wrangler deploy`;
// this file tells wrangler to publish `dist/` as a static site with SPA routing.
{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "arrow-crm",
    "compatibility_date": "2026-07-15",
    "assets": {
        "directory": "./dist",
        "not_found_handling": "single-page-application"
    }
}
